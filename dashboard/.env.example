# Unstructured Alpha — environment variables (example)
# ---------------------------------------------------------------------------
# Copy to `.env` for local dev and fill in real values. In production these are
# set per-service in the Render dashboard / render.yaml (secrets use `sync:false`
# in render.yaml and are entered in the dashboard, never committed).
#
# NEVER commit real secrets. This file documents the variable NAMES only.
# ---------------------------------------------------------------------------

# ── Core ────────────────────────────────────────────────────────────────────
# Postgres connection string (Neon). The app reads DATABASE_URL; a couple of
# scripts also accept UNSTRUCTURED_ALPHA_DATABASE_URL as an override.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# UNSTRUCTURED_ALPHA_DATABASE_URL=            # optional override

# Set automatically by Render — do NOT set locally unless you know why:
# PORT=                                        # Render injects the bind port
# RENDER_EXTERNAL_URL=                         # public URL of the service
# RENDER_GIT_COMMIT=                           # commit SHA (shown at /version)

# ── Rate limiting / cache (Redis) ───────────────────────────────────────────
# Render Key Value (managed Redis). Internal private-network hostname in prod.
# If unset, utils/ratelimit.py transparently falls back to an in-process limiter.
REDIS_URL=redis://red-xxxxxxxxxxxx:6379

# ── Data providers ──────────────────────────────────────────────────────────
FRED_API_KEY=your_fred_api_key
EIA_API_KEY=your_eia_api_key

# ── AI (Pro "AI Assistant" + score explanations) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@unstructuredalpha.com
RESEND_AUDIENCE_ID=your_audience_id

# ── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_ID=price_...                      # monthly Pro price
STRIPE_ANNUAL_PRICE_ID=price_...               # annual Pro price

# ── Social (X / Twitter) — cron posting, optional ───────────────────────────
# Currently disabled (X API 402 / credits depleted). Leave posting off.
TWITTER_POSTING_ENABLED=false
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── Analytics (optional; app works without) ─────────────────────────────────
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=internal                    # internal | posthog
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com

# ── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated allowlist of admin emails (see utils/billing.ADMIN_EMAILS).
ADMIN_EMAILS=bpgiri2005@gmail.com

# ── URLs ────────────────────────────────────────────────────────────────────
APP_URL=https://unstructuredalpha.com
APP_BASE_URL=https://app.unstructuredalpha.com
SEO_BASE_URL=https://seo.unstructuredalpha.com

# ── Performance tuning (all optional; safe defaults in code) ────────────────
# See PERFORMANCE.md. These let you tune without a code change.
LOG_LEVEL=INFO                                 # DEBUG for verbose structured logs
SIGNAL_SCORE_WORKERS=8                          # cold-start signal fan-out (1..16)
RECOMMENDER_WORKERS=5                            # Recommender scan workers (1..16)
MALLOC_ARENA_MAX=2                               # glibc arenas; raise only on many-core plans
